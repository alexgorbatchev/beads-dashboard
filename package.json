{
  "name": "beads-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:ui": "vite",
    "dev:server": "bun --watch server/index.ts",
    "dev:all": "bun run --parallel dev:ui dev:server",
    "build": "tsc -b && vite build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --deny-warnings .",
    "fix:semantic": "typescript-ai-policy-fix-semantic -- .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "bun test server/__tests__",
    "storybook": "storybook dev --ci --port 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@alexgorbatchev/typescript-ai-policy": "^5.0.3",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/builder-vite": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.4",
    "jsdom": "^29.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "4.1.4"
  }
}